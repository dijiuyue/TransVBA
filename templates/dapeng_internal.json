{
  "template_name": "dapeng_internal",
  "template_display": "大鹏公司内部标准",
  "template_description": "适用于内部汇报、特定项目",

  "body": {
    "font": "宋体",
    "size": "小四",
    "spacing": 1.5,
    "before_lines": 0.0,
    "after_lines": 0.0,
    "alignment": "两端对齐",
    "left_indent_cm": 0.0,
    "right_indent_cm": 0.0,
    "special_indent": "首行缩进",
    "special_indent_chars": 2.0
  },

  "titles": [
    {
      "alignment": "左对齐",
      "font": "宋体",
      "size": "小四",
      "bold": true,
      "before_lines": 0.0,
      "after_lines": 0.0,
      "line_spacing": 1.5
    },
    {
      "alignment": "左对齐",
      "font": "宋体",
      "size": "小四",
      "bold": true,
      "before_lines": 0.0,
      "after_lines": 0.0,
      "line_spacing": 1.5
    },
    {
      "alignment": "左对齐",
      "font": "宋体",
      "size": "小四",
      "bold": true,
      "before_lines": 0.0,
      "after_lines": 0.0,
      "line_spacing": 1.5
    },
    {
      "alignment": "左对齐",
      "font": "宋体",
      "size": "小四",
      "bold": false,
      "before_lines": 0.0,
      "after_lines": 0.0,
      "line_spacing": 1.5
    },
    {
      "alignment": "左对齐",
      "font": "宋体",
      "size": "小四",
      "bold": false,
      "before_lines": 0.0,
      "after_lines": 0.0,
      "line_spacing": 1.5
    }
  ],

  "table": {
    "title_font": "宋体",
    "title_size": "小四",
    "title_bold": false,
    "title_alignment": "居中",
    "title_before_lines": 0.0,
    "title_after_lines": 0.0,
    "title_spacing": 1.5,
    "title_left_indent_cm": 0.0,
    "title_right_indent_cm": 0.0,
    "title_special_indent": "无",
    "title_special_indent_cm": 0.0,
    "body_font": "宋体",
    "body_size": "小四",
    "line_width_pt": 0.5,
    "spacing": 1.5,
    "auto_fit_mode": "window"
  },

  "figure": {
    "title_font": "宋体",
    "title_size": "小四",
    "title_bold": false,
    "title_alignment": "居中",
    "title_before_lines": 0.0,
    "title_after_lines": 0.0,
    "title_spacing": 1.5,
    "title_left_indent_cm": 0.0,
    "title_right_indent_cm": 0.0,
    "title_special_indent": "无",
    "title_special_indent_cm": 0.0
  },

  "cover": {
    "font": "宋体",
    "size": "二号",
    "bold": true,
    "line_spacing": 1.5,
    "alignment": "居中",
    "max_length": 80,
    "search_paragraphs": 15
  },

  "appendix": {
    "title_font": "宋体",
    "title_size": "小四",
    "title_bold": true,
    "title_line_spacing": 1.5,
    "body_font": "宋体",
    "body_size": "小五",
    "body_bold": false,
    "body_line_spacing": 1.0
  },

  "header": {
    "font": "宋体",
    "size": "小五",
    "bold": false,
    "line_spacing": 1.0
  },

  "toc": {
    "title_font": "宋体",
    "title_size": "二号",
    "title_bold": true,
    "title_spacing": 1.5,
    "level1_font": "宋体",
    "level1_size": "小四",
    "level1_bold": true,
    "level2_font": "宋体",
    "level2_size": "小四",
    "level2_indent_chars": 2,
    "level3_font": "宋体",
    "level3_size": "小四",
    "level3_indent_chars": 4
  },

  "auto_detect_numeric_titles": true,
  "auto_detect_include_list_paragraphs": true,
  "remember_settings": true,
  "prefer_com_resolver": true,

  "validation": {
    "check_table_row_height": false,
    "check_table_font_size": false,
    "check_cover_title_size": true,
    "check_appendix_body_size": true,
    "check_grid_alignment": true,
    "check_chairman_number": false,
    "check_appendix_colon": true,
    "check_figure_table_space": true,
    "check_forbidden_words": true,
    "forbidden_words": ["附图", "附表"],
    "forbidden_replacements": {"附图": "附件", "附表": "附件"},
    "check_figure_position": true,
    "check_brackets": true,
    "check_period": true,
    "check_ascii_font": true,
    "check_chinese_font": true,
    "check_spacing": true,
    "check_caption_alignment": true,
    "check_table_fixed_dimensions": true
  }
}
